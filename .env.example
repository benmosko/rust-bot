# Wallet
POLYMARKET_PRIVATE_KEY=0x...your_polygon_private_key...
SIGNATURE_TYPE=0
FUNDER_ADDRESS=

# RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Spread Capture (gabagool) — FAK limit at best ask, many small DCA fills (no resting GTC)
# Only consider a side when best_ask <= this (cheap entry band)
SC_CHEAP_SIDE_MAX_ASK=0.45
# Max sum of average YES + average NO after a simulated buy (only when both legs have size)
SC_MAX_PAIR_COST=0.98
# Do not buy YES if yes_qty > no_qty + this (symmetric for NO)
SC_MAX_QTY_IMBALANCE=10
# Max market-rounds with spread-capture inventory at once
SC_MAX_ACTIVE_MARKETS=2
# Shares per FAK tap (DCA bite size)
SC_FAK_ORDER_SIZE=5
# Min ms between FAK orders on the same side (YES vs NO tracked separately)
SC_ORDER_COOLDOWN_MS=500
# If true, spread capture runs only on 15m markets (5m left for sniper)
SC_PREFER_15M=true
SC_MAX_IMBALANCE_PCT=0.10

# Momentum
MOM_MIN_SPOT_MOVE_PCT=0.003
MOM_LATE_ENTRY_MIN_BID=0.85
MOM_PREEMPTIVE_CANCEL_MS=100

# Market Making
MM_HALF_SPREAD=0.02
MM_VOLATILITY_SPREAD=0.04
MM_MAX_INVENTORY_PER_SIDE=500
MM_INVENTORY_IMBALANCE_LIMIT=50
MM_STOP_BEFORE_END_SECS=30

# Sniper (late entry)
SNIPE_MIN_BID=0.90
SNIPE_MAX_SPREAD=0.03
SNIPE_MIN_ELAPSED_PCT=0.70
SNIPE_POSITION_SIZE_PCT=0.90
SNIPE_MAX_REPLACEMENTS=3
SNIPE_NO_CROSSOVER_SECS=45
SNIPER_MAX_SHARES=10
# Fraction of balance to deploy per snipe (1% = 0.01); size = max(floor(balance * pct / price), min)
SNIPER_CAPITAL_DEPLOY_PCT=0.01
SNIPER_MIN_SHARES=3
# Max confirmed primary sniper fills per period slot (shared across all coins); then cancel remaining GTCs
SNIPER_MAX_FILLS_PER_ROUND=2
# Minimum best_ask on a side before sniper may enter (orderbook events + entry gate)
SNIPER_ENTRY_MIN_BEST_ASK=0.96
# Seconds before round end when sniper may activate: ≤5m rounds vs >5m rounds (e.g. 15m, 60m)
SNIPER_ENTRY_WINDOW_5M=60
SNIPER_ENTRY_WINDOW_15M=180
# Single-leg sniper: FAK hedge other side when fill_price + best_ask ≤ this (set to 1.00 to disable)
SNIPER_HEDGE_MAX_PAIR_COST=0.99

# Risk
MAX_CONCURRENT_ROUNDS=4
DAILY_LOSS_LIMIT_PCT=0.20
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_SECS=1800
MAX_ROUND_EXPOSURE_PCT=0.40
VOLATILITY_PAUSE_THRESHOLD_PCT=0.03
VOLATILITY_PAUSE_SECS=300

# Markets
COINS=btc,eth,sol,xrp
PERIODS=5,15

# Performance
CANCEL_REPLACE_TARGET_MS=100
CANCEL_REPLACE_HARD_LIMIT_MS=200

# Logging
RUST_LOG=info
# Rolling log filename prefix under ./logs/ (daily files: logs/<prefix>.YYYY-MM-DD)
LOG_FILE=bot.log

# Strategy Mode
# Possible values: sniper_only, gabagool_only, all
# Default: sniper_only
STRATEGY_MODE=sniper_only

# Telegram (optional). Mini App needs a public HTTPS URL + reverse proxy to TELEGRAM_WEBAPP_BIND.
# No defaults in code — set both to non-empty to enable (never commit real values).
# Required for supervisor binary and for polymarket-supervisor.service (EnvironmentFile loads this .env).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Public origin only (no trailing slash). Mini Apps: {URL}/telegram-positions, {URL}/telegram-dashboard (live)
# Required for "live dashboard" buttons in Telegram. Local dev: expose TELEGRAM_WEBAPP_BIND with ngrok/cloudflared, then set this to the https://... URL they give you.
# Remote control: /pause (stop new orders + cancel open), /resume, /status
# TELEGRAM_WEBAPP_PUBLIC_URL=https://your-domain.com
# Local HTTP listen (use 127.0.0.1 behind nginx/Caddy TLS)
# TELEGRAM_WEBAPP_BIND=127.0.0.1:8787
# Windows: auto-set PUBLIC_URL via ngrok — .\scripts\dev-bot-with-ngrok.ps1 (needs ngrok + one-time authtoken)
#
# Standalone (polybot / polymarket-bot.exe): omit DISABLE_TELEGRAM_POLLING — Telegram polling defaults ON.
# Supervisor child: DISABLE_TELEGRAM_POLLING=true is set by the supervisor process (spawn); you do not set it for /startbot.
# Optional: absolute path to polymarket-bot binary if not target/release/polymarket-bot
# POLYBOT_BINARY=/home/ubuntu/polymarket-bot/target/release/polymarket-bot
# STRATEGY_DB_PATH=logs/strategy.db

# Dry Run
DRY_RUN=true
